<Window x:Class="AplicativoDeAlmacen.Views.PermisosRolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Matriz de Seguridad y Accesos" Height="650" Width="950"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" FontFamily="Segoe UI" Background="#F3F4F6">

    <Window.Resources>
        <CollectionViewSource x:Key="PermisosAgrupados">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="CategoriaModulo"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#1E293B" CornerRadius="12,12,0,0" Padding="25">
            <StackPanel>
                <TextBlock Text="Matriz de Privilegios del Sistema" Foreground="#94A3B8" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Configurando accesos para el rol: " Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TxtNombreRol" Text="ROL" Foreground="#38BDF8" FontSize="20" FontWeight="Black"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,12,12" ClipToBounds="True">
            <DataGrid x:Name="PermisosDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserSortColumns="False" 
                      BorderThickness="0" RowHeight="45" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" 
                      Background="White" HeadersVisibility="Column" ItemsSource="{Binding Source={StaticResource PermisosAgrupados}}">

                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <StackPanel>
                                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,1,0,1" Padding="15,10">
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#334155" FontSize="15"/>
                                                </Border>
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F5F9"/>
                        <Setter Property="Foreground" Value="#475569"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,12"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="MÓDULO DEL SISTEMA" Binding="{Binding NombreModulo}" Width="*" IsReadOnly="True">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="20,0,0,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="VER" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <CheckBox Click="ChkAllVer_Click" HorizontalAlignment="Center" ToolTip="Seleccionar Todo"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding PuedeVer, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="CREAR" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <CheckBox Click="ChkAllCrear_Click" HorizontalAlignment="Center" ToolTip="Seleccionar Todo"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding PuedeCrear, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="EDITAR" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <CheckBox Click="ChkAllEditar_Click" HorizontalAlignment="Center" ToolTip="Seleccionar Todo"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding PuedeEditar, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="ELIMINAR" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <CheckBox Click="ChkAllEliminar_Click" HorizontalAlignment="Center" ToolTip="Seleccionar Todo"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding PuedeEliminar, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="90">
                        <DataGridTemplateColumn.Header>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="IMPRIMIR" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <CheckBox Click="ChkAllImprimir_Click" HorizontalAlignment="Center" ToolTip="Seleccionar Todo"/>
                            </StackPanel>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding PuedeImprimir, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="❌ Cancelar" Width="130" Height="45" Background="White" Foreground="#64748B" FontWeight="Bold" FontSize="14" BorderThickness="1" BorderBrush="#CBD5E1" Cursor="Hand" Margin="0,0,12,0" Click="BtnCancelar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="💾 Guardar Políticas" Width="200" Height="45" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnGuardar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>