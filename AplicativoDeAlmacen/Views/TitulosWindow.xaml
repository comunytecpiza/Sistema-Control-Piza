<Window x:Class="AplicativoDeAlmacen.Views.TitulosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Títulos" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="Buscar:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"/>
            <TextBox x:Name="BuscarTextBox" Width="250" Margin="0,0,10,0" TextChanged="BuscarTextBox_TextChanged"/>
            <Button Content="+ Agregar Título" Click="AgregarTitulo_Click" Width="150" Margin="0,0,10,0"  Background="Green" Foreground="White" Padding="5" FontSize="15"/>
            <Button Content="Editar Título" Click="EditarTitulo_Click" Width="150" Background="Orange" Foreground="White" Padding="5" FontSize="15"/>
        </StackPanel>

        <DataGrid x:Name="TitulosDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="TitulosDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Descripción" Binding="{Binding Nombre}"/>
                <DataGridTextColumn Header="Estado" Binding="{Binding Estado}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Modal para Agregar/Editar Título -->
        <Grid x:Name="ModalBackground" Grid.RowSpan="2" Visibility="Collapsed" Background="#80000000">
            <Border Background="White" CornerRadius="5" Width="300" Height="235">
                <StackPanel Margin="10">
                    <TextBlock x:Name="ModalTitle" Text="Agregar Nuevo Título" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
                    <TextBlock Text="Descripción:" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBox x:Name="DescripcionTextBox" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <TextBlock Text="Estado:" FontSize="15" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ComboBox x:Name="EstadoComboBox" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Agregar" Click="Agregar_Click" Width="120" Margin="0,0,10,0" Background="Green" Foreground="White" Padding="5" FontSize="15" />
                        <Button Content="Cancelar" Click="Cancelar_Click" Width="120"  Background="Red" Foreground="White" Padding="5" FontSize="15"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>