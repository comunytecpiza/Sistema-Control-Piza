<Window x:Class="AplicativoDeAlmacen.Views.ZonasPromotoriaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zonas de Promotoria" Height="450" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Zonas de Promotoría" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Localidad"/>
            <ComboBox x:Name="LocalidadComboBox" SelectionChanged="LocalidadComboBox_SelectionChanged"/>
        </StackPanel>

        <ListBox x:Name="ZonasListBox" Grid.Row="2" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="+ Agregar Zona" Click="AgregarZona_Click" Background="Green" Foreground="White" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="- Eliminar Zona" Click="EliminarZona_Click" Background="Red" Foreground="White" Padding="10,5"/>
        </StackPanel>
    </Grid>
</Window>