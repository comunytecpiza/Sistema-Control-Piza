<Window x:Class="AplicativoDeAlmacen.Views.RegistroCodigosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registro de Códigos" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="Colección:" VerticalAlignment="Center" FontSize="15"/>
            <ComboBox x:Name="ColeccionComboBox" Width="100" Margin="5,0,10,0" SelectionChanged="ColeccionComboBox_SelectionChanged" Padding="5" FontSize="15"/>
            <RadioButton x:Name="LibroGuiaRadioButton" Content="Libros Guía" IsChecked="True" Margin="0,07,10,0" Checked="TipoLibro_Checked" GroupName="TipoLibro" FontSize="15"/>
            <RadioButton x:Name="LibroVentaRadioButton" Content="Libros Venta" Margin="0,07,10,0" Checked="TipoLibro_Checked" GroupName="TipoLibro" FontSize="15"/>
            <Button Content="Agregar Códigos" Click="AgregarCodigos_Click" Width="150" Background="Green" Foreground="White" Padding="5" FontSize="15"/>
            <Button Content="Eliminar Códigos" Click="EliminarCodigos_Click" Width="150" Margin="10,0,0,0" Background="Red" Foreground="White" Padding="5" FontSize="15"/>
        </StackPanel>
        <DataGrid x:Name="CodigosDataGrid" Grid.Row="1" AutoGenerateColumns="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" FontSize="15"/>
                <DataGridTextColumn Header="U. Medida" Binding="{Binding UnidadMedida}" FontSize="15"/>
                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" FontSize="15"/>
                <DataGridTextColumn Header="Desde" Binding="{Binding Desde}" FontSize="15"/>
                <DataGridTextColumn Header="Hasta" Binding="{Binding Hasta}" FontSize="15"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid x:Name="ModalAgregarCodigo" Grid.RowSpan="3" Visibility="Collapsed" Background="#80000000">
            <Border Background="White" CornerRadius="5" Width="400" Height="525" Padding="20">
                <StackPanel>
                    <TextBlock Text="Agregar Nuevo Código" FontWeight="Bold" FontSize="20" Margin="0,0,0,20"/>
                    <TextBlock Text="Producto:" FontSize="15" FontWeight="Bold" Margin="0,0,0,05"/>
                    <ComboBox x:Name="ProductoComboBox" 
          IsEditable="True"
          IsTextSearchEnabled="True"
          TextSearch.TextPath="Descripcion"
          TextBoxBase.TextChanged="ProductoComboBox_TextChanged"
          SelectionChanged="ProductoComboBox_SelectionChanged"
          DisplayMemberPath="Descripcion"
          Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <TextBlock Text="Colección:" FontSize="15" FontWeight="Bold" Margin="0,0,0,05"/>
                    <ComboBox x:Name="ModalColeccionComboBox" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <TextBlock Text="Categoría de Producto:" FontSize="15" FontWeight="Bold" Margin="0,0,0,05"/>
                    <ComboBox x:Name="CategoriaComboBox" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <TextBlock Text="Cantidad:" FontSize="15" FontWeight="Bold" Margin="0,0,0,05"/>
                    <TextBox x:Name="CantidadTextBox" Margin="0,0,0,10" TextChanged="CantidadTextBox_TextChanged" FontSize="15" Padding="5"/>
                    <TextBlock Text="Desde:" FontSize="15" FontWeight="Bold" Margin="0,0,0,05"/>
                    <TextBox x:Name="DesdeTextBox" IsReadOnly="True" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <TextBlock Text="Hasta:" FontSize="15" FontWeight="Bold" Margin="0,0,0,05"/>
                    <TextBox x:Name="HastaTextBox" IsReadOnly="True" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Guardar" Click="GuardarCodigos_Click" Width="120" Margin="0,0,10,0" Background="Green" Foreground="White" Padding="5" FontSize="15" FontWeight="Bold"/>
                        <Button Content="Cancelar" Click="CerrarModal_Click" Width="120" Background="Red" Foreground="White" Padding="5" FontSize="15" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>