<UserControl x:Class="AplicativoDeAlmacen.Views.ProductosUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📦 Catálogo de Productos" FontSize="26" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔍 Buscar:" VerticalAlignment="Center" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBox x:Name="BuscarTextBox" Width="300" TextChanged="BuscarTextBox_TextChanged" FontSize="14" ToolTip="Buscar por código, descripción..."/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="+ Agregar" Click="AgregarProductoButton_Click" Background="#10B981" Margin="0,0,10,0" MinWidth="110"/>
                <Button Content="✏️ Editar" Click="EditarProductoButton_Click" Background="#F59E0B" Margin="0,0,10,0" MinWidth="110"/>
                <Button Content="🗑️ Eliminar" Click="EliminarProductoButton_Click" Background="#EF4444" MinWidth="110"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" CornerRadius="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" Padding="1">
            <DataGrid x:Name="ProductosDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="Transparent" BorderThickness="0" 
                      RowHeight="35" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F9FAFB"/>
                        <Setter Property="Foreground" Value="#374151"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cód." Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Descripción del Producto" Binding="{Binding Descripcion}" Width="*"/>
                    <DataGridTextColumn Header="Abrev." Binding="{Binding Abreviatura}" Width="90"/>
                    <DataGridTextColumn Header="U. Medida" Binding="{Binding UnidadMedida.Descripcion}" Width="100"/>
                    <DataGridTextColumn Header="P. Unitario" Binding="{Binding PrecioUnitario, StringFormat=S/ {0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="%" Binding="{Binding Porcentaje, StringFormat={}{0:N2} %}" Width="80"/>
                    <DataGridTextColumn Header="IGV" Binding="{Binding afectacion.Nombre}" Width="120"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado.Nombre}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid x:Name="ProductoModal" Visibility="Collapsed" Background="#80000000" Grid.RowSpan="3" Margin="-20">
            <Border Background="White" Width="850" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="12" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="5" Opacity="0.3" Direction="270"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock x:Name="ModalTitle" FontSize="22" FontWeight="Bold" Foreground="#1F2937" Margin="0,0,0,15" TextAlignment="Center"/>
                    <Border Height="1" Background="#E5E7EB" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📝 Datos Generales" Foreground="#3B82F6" FontWeight="Bold" Margin="0,0,0,10"/>

                            <TextBlock Text="Descripción" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtDescripcion" Margin="0,0,0,15" Height="30"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Abreviatura" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtAbreviatura"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Tipo de Producto" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbTipoProducto" 
                                                                      SelectionChanged="CmbTipoProducto_SelectionChanged"
                                                                      DisplayMemberPath="Nombre" 
                                                                      SelectedValuePath="Id" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="💰 Precio y Facturación" Foreground="#3B82F6" FontWeight="Bold" Margin="0,15,0,10"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Precio Unitario" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtPrecioUnitario" LostFocus="TxtDecimal_LostFocus"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Porcentaje (%)" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtPorcentaje" LostFocus="TxtDecimal_LostFocus"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Unidad de Medida" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbUnidadMedida"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Afectación IGV" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbAfectacionIgv"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="📚 Datos Académicos" Foreground="#3B82F6" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nivel" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbNivel" SelectionChanged="CmbNivel_SelectionChanged"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Grado" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CmbGrado" DisplayMemberPath="Nombre" SelectedValuePath="Id" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Curso" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CmbCurso" Margin="0,0,0,15" SelectionChanged="CmbCurso_SelectionChanged"/>

                            <CheckBox x:Name="ChkTitulo" Content="Vincular Título de Curso" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5" Checked="ChkTitulo_Checked" Unchecked="ChkTitulo_Unchecked"/>
                            <ComboBox x:Name="CmbTitulo" Margin="0,0,0,30" IsEnabled="False"/>

                            <TextBlock Text="⚙️ Configuración" Foreground="#3B82F6" FontWeight="Bold" Margin="0,0,0,10"/>

                            <TextBlock Text="Estado" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CmbEstado" Width="180" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    <Border Height="1" Background="#E5E7EB" Margin="0,20,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Click="BtnCancelarProducto_Click" Background="#6B7280" Margin="0,0,10,0" Width="100"/>
                        <Button x:Name="BtnGuardarProducto" Content="Guardar" Click="BtnGuardarProducto_Click" Background="#3B82F6" Width="120"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>