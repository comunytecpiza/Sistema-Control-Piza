<UserControl x:Class="AplicativoDeAlmacen.Views.UsuariosUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6" FontFamily="Segoe UI" MinHeight="600" MinWidth="1000">

    <Grid Margin="25">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6.5*"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,25,0" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#1E293B" Padding="25,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="👥" FontSize="22" Margin="0,0,10,0"/>
                            <TextBlock Text="Control y Gestión de Usuarios" Foreground="White" FontWeight="SemiBold" FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Filtro rápido:" Foreground="#94A3B8" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold"/>
                            <Border Background="#334155" CornerRadius="8" Padding="10,5" BorderBrush="#475569" BorderThickness="1">
                                <TextBox x:Name="TxtBuscar" Width="220" Height="28" Foreground="White" FontSize="14" CaretBrush="White" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" TextChanged="TxtBuscar_TextChanged"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid x:Name="UsuariosDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" HeadersVisibility="Column" RowHeight="45" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" SelectionChanged="UsuariosDataGrid_SelectionChanged" Background="White">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="#64748B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CÓDIGO" Binding="{Binding Username}" Width="100" FontWeight="Bold" Foreground="#3B82F6"/>
                        <DataGridTextColumn Header="APELLIDOS Y NOMBRES" Binding="{Binding Nombres}" Width="*"/>
                        <DataGridTextColumn Header="ROL ASIGNADO" Binding="{Binding Rol.Nombre}" Width="160" FontWeight="SemiBold" Foreground="#4F46E5"/>
                        <DataGridTextColumn Header="ESTADO" Binding="{Binding EstadoNombre}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Estado}" Value="True">
                                            <Setter Property="Foreground" Value="#059669"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Estado}" Value="False">
                                            <Setter Property="Foreground" Value="#E11D48"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Ficha del Usuario" FontSize="22" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,30"/>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="CÓDIGO DE ACCESO" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtCodigo" IsReadOnly="True" Background="#F8FAFC" Height="42" Padding="15,0" VerticalContentAlignment="Center" Foreground="#3B82F6" FontWeight="Bold" FontSize="15" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,0,20"/>

                    <TextBlock Text="APELLIDOS Y NOMBRES" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBox x:Name="TxtNombres" Height="42" Padding="15,0" VerticalContentAlignment="Center" FontSize="15" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20"/>

                    <TextBlock Text="CLAVE SECRETA" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="TxtPassword" Height="42" Padding="15,0" VerticalContentAlignment="Center" FontSize="15" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ROL DE OPERACIÓN" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CboRol" Height="42" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ESTADO" Foreground="#64748B" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CboEstado" Height="42" VerticalContentAlignment="Center" Padding="10,0" FontSize="15" BorderBrush="#CBD5E1">
                                <ComboBoxItem Content="ACTIVO" Tag="true" IsSelected="True" Foreground="#059669" FontWeight="SemiBold"/>
                                <ComboBoxItem Content="INACTIVO" Tag="false" Foreground="#E11D48" FontWeight="SemiBold"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="BtnAccesos" Content="🔐 Configurar Permisos Detallados" Height="48" Background="#F59E0B" Foreground="White" FontWeight="Bold" FontSize="15" Cursor="Hand" BorderThickness="0" Click="BtnAccesos_Click">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="#F59E0B"/>
                        </Button.Effect>
                    </Button>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,30,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnNuevo" Content="✨ Nuevo" Grid.Column="0" Margin="0,0,10,0" Height="45" Background="#3B82F6" Foreground="White" FontWeight="Bold" FontSize="15" BorderThickness="0" Cursor="Hand" Click="BtnNuevo_Click">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnGuardar" Content="💾 Guardar" Grid.Column="1" Margin="5,0,5,0" Height="45" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="15" BorderThickness="0" Cursor="Hand" Click="BtnGuardar_Click">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnCancelar" Content="❌ Cancelar" Grid.Column="2" Margin="10,0,0,0" Height="45" Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="15" BorderThickness="0" Cursor="Hand" Click="BtnCancelar_Click">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>