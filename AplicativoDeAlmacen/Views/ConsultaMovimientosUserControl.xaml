<UserControl x:Class="AplicativoDeAlmacen.Views.ConsultaMovimientosUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6" FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="RightAlignStyle" TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="0,0,15,0"/>
        </Style>
        <Style x:Key="IngresoStyle" TargetType="DataGridCell" BasedOn="{StaticResource RightAlignStyle}">
            <Setter Property="Foreground" Value="#059669"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="SalidaStyle" TargetType="DataGridCell" BasedOn="{StaticResource RightAlignStyle}">
            <Setter Property="Foreground" Value="#DC2626"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.06"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Producto Maestro:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,20,15"/>
                    <ComboBox x:Name="CboProductos" Grid.Column="1" Height="40" IsEditable="True" Margin="0,0,0,15" SelectionChanged="CboProductos_SelectionChanged" FontSize="14" BorderBrush="#CBD5E1"/>

                    <TextBlock Text="Filtros de Auditoría:" Grid.Row="1" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="#475569" Margin="0,0,20,15"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkRazonSocial" Content="Razón Social:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#334155" FontWeight="SemiBold" Click="ChkFiltros_Click"/>
                        <TextBox x:Name="TxtRazonSocial" Width="220" Height="36" Margin="0,0,30,0" IsEnabled="False" VerticalContentAlignment="Center" Padding="10,0" FontSize="13" BorderBrush="#CBD5E1"/>

                        <CheckBox x:Name="ChkUbicacion" Content="Ubicación:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#334155" FontWeight="SemiBold" Click="ChkFiltros_Click"/>
                        <TextBox x:Name="TxtUbicacion" Width="220" Height="36" IsEnabled="False" VerticalContentAlignment="Center" Padding="10,0" FontSize="13" BorderBrush="#CBD5E1"/>
                    </StackPanel>

                    <TextBlock Text="Rango de Fechas:" Grid.Row="2" VerticalAlignment="Center" FontWeight="Bold" FontSize="13" Foreground="#475569"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Desde" VerticalAlignment="Center" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <DatePicker x:Name="DpDesde" Width="140" Height="38" Margin="0,0,25,0" BorderBrush="#CBD5E1"/>

                        <TextBlock Text="Hasta" VerticalAlignment="Center" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <DatePicker x:Name="DpHasta" Width="140" Height="38" Margin="0,0,35,0" BorderBrush="#CBD5E1"/>

                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="15,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tipo de Operación:" FontWeight="Bold" Foreground="#475569" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RbGuia" Content="Solo Guías" Margin="0,0,15,0" Foreground="#334155" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RbVenta" Content="Solo Ventas" Margin="0,0,15,0" Foreground="#334155" VerticalAlignment="Center"/>
                                <RadioButton x:Name="RbTodos" Content="Todos" IsChecked="True" Foreground="#334155" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Bottom">
                    <Button Content="🚀 Ejecutar Consulta" Height="45" Width="180" Margin="0,0,0,10" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnEjecutar_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="🖨️ Imprimir Reporte" Height="45" Width="180" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6.5*"/>
                <ColumnDefinition Width="3.5*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,15,0" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#1E293B" Padding="20,12">
                        <TextBlock Text="📋 Libro de Movimientos Contables" Foreground="White" FontWeight="Bold" FontSize="15"/>
                    </Border>

                    <DataGrid x:Name="MovimientosDataGrid" SelectionChanged="MovimientosDataGrid_SelectionChanged" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" HeadersVisibility="Column" RowHeight="38" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" AlternatingRowBackground="#F8FAFC">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="90"/>
                            <DataGridTextColumn Header="Comprobante" Binding="{Binding NumeroRegistro}" Width="120"/>
                            <DataGridTextColumn Header="Guía Remisión" Binding="{Binding NumeroGuia}" Width="110"/>
                            <DataGridTextColumn Header="Razón Social / Entidad" Binding="{Binding RazonSocialUbicacion}" Width="*"/>
                            <DataGridTextColumn Header="ENTRAN" Binding="{Binding Ingreso, StringFormat=N2}" Width="90" CellStyle="{StaticResource IngresoStyle}"/>
                            <DataGridTextColumn Header="SALEN" Binding="{Binding Salida, StringFormat=N2}" Width="90" CellStyle="{StaticResource SalidaStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#F8FAFC" Padding="15" BorderBrush="#E2E8F0" BorderThickness="0,2,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#ECFDF5" BorderBrush="#34D399" BorderThickness="1" CornerRadius="8" Padding="15,10" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Total Entradas" Foreground="#065F46" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="TxtTotalIngreso" Text="0.00" Foreground="#047857" FontWeight="Black" FontSize="20"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#FEF2F2" BorderBrush="#F87171" BorderThickness="1" CornerRadius="8" Padding="15,10" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Total Salidas" Foreground="#991B1B" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="TxtTotalSalida" Text="0.00" Foreground="#B91C1C" FontWeight="Black" FontSize="20"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#EFF6FF" BorderBrush="#818CF8" BorderThickness="1" CornerRadius="8" Padding="15,10">
                                <StackPanel>
                                    <TextBlock Text="Ventas / Salidas Netas" Foreground="#3730A3" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="TxtTotalVendidos" Text="0.00" Foreground="#4338CA" FontWeight="Black" FontSize="20"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#4338CA" Padding="20,12">
                        <TextBlock Text="🏷️ Códigos de la Operación" Foreground="White" FontWeight="Bold" FontSize="15"/>
                    </Border>

                    <DataGrid x:Name="CodigosDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" HeadersVisibility="Column" RowHeight="35" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código QR / Físico" Binding="{Binding Codigo}" Width="*" FontWeight="SemiBold" Foreground="#334155"/>
                            <DataGridTextColumn Header="Tipo Asignado" Binding="{Binding ColeccionTipo}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#F8FAFC" Padding="15" BorderBrush="#E2E8F0" BorderThickness="0,2,0,0">
                        <Border Background="#EEF2FF" CornerRadius="15" Padding="10,8" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtTotalCodigos" Text="Seleccione un movimiento para auditar códigos" FontWeight="Bold" Foreground="#4F46E5" FontSize="13"/>
                        </Border>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>