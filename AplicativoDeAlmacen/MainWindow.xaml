<Window x:Class="AplicativoDeAlmacen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AplicativoDeAlmacen"
        mc:Ignorable="d"
        Title="Control de Almacén Piza" Height="650" Width="1100" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#DC2626"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#E5E7EB"/>
                    <Setter Property="Foreground" Value="#9CA3AF"/>
                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#DC2626"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BtnPrincipal" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B91C1C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#991B1B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7F1D1D" Offset="0.0" />
                    <GradientStop Color="#B91C1C" Offset="0.5" />
                    <GradientStop Color="#FFEA4141" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Border Background="White" Opacity="0.04">
                <Border.OpacityMask>
                    <VisualBrush TileMode="Tile" Viewport="0,0,30,30" ViewportUnits="Absolute">
                        <VisualBrush.Visual>
                            <Path Data="M 0,30 L 30,0" Stroke="Black" StrokeThickness="1"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
            </Border>
        </Border>

        <Border Background="White" CornerRadius="20" Padding="45,40"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="420">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Direction="270" Color="Black" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>
                <Image Source="Images/logo.png" Height="80" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                <TextBlock FontSize="26" FontWeight="Bold" Foreground="#DC2626" TextAlignment="Center" Margin="0,0,0,30">
                    CONTROL
                </TextBlock>

                <TextBlock Text="Usuario" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="14"/>
                <TextBox x:Name="UsernameTextBox" 
                         TextChanged="UsernameTextBox_TextChanged" 
                         KeyDown="UsernameTextBox_KeyDown" 
                         Height="45" Margin="0,0,0,15"/>

                <TextBlock Text="Nombre Asignado" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="14"/>
                <TextBox x:Name="NameTextBox" 
                         IsReadOnly="True" Focusable="False"
                         Height="45" Margin="0,0,0,15"/>

                <TextBlock Text="Contraseña" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="14"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <PasswordBox x:Name="PasswordBox" 
                                 KeyDown="PasswordBox_KeyDown" 
                                 Height="45" Width="280" Margin="0,0,10,0"/>

                    <Button Content="👁️" Width="40" Height="45" Click="ShowPassword_Click" 
                            Background="#F3F4F6" Foreground="#4B5563" FontSize="16" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Button x:Name="IngresarButton" Click="IngresarButton_Click" Content="INGRESAR AL SISTEMA" 
                        Style="{StaticResource BtnPrincipal}" Height="50" Margin="0,0,0,10"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>