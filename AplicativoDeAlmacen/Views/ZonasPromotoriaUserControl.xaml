<UserControl x:Class="AplicativoDeAlmacen.Views.ZonasPromotoriaUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F9" FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🌍 Zonas de Promotoría" FontSize="26" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Seleccionar Localidad:" FontWeight="SemiBold" Foreground="#4A5568"/>
                    <ComboBox x:Name="LocalidadComboBox" SelectionChanged="LocalidadComboBox_SelectionChanged" Height="35" Margin="0,5,0,0"/>
                </StackPanel>

                <ListBox x:Name="ZonasListBox" Grid.Row="1" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,5" Background="#F7FAFC" CornerRadius="4" Width="300">
                                <TextBlock Text="{Binding Descripcion}" FontWeight="Medium"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button Content="+ Agregar" Click="AgregarZona_Click" Background="#10B981" Width="120" Margin="0,0,10,0"/>
                    <Button Content="🗑️ Eliminar" Click="EliminarZona_Click" Background="#EF4444" Width="120"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>