<Window x:Class="AplicativoDeAlmacen.Views.AlmacenPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel de Almacén - Ediciones Piza" Height="700" Width="1100"
        WindowState="Maximized" 
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="White">
    <Window.Resources>
        <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                    <Setter Property="Foreground" Value="#DC2626"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="MenuItem" BasedOn="{StaticResource ModernMenuItemStyle}">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" 
                                Padding="12,8" 
                                Margin="0,0,4,0" 
                                Background="#E5E7EB" 
                                BorderBrush="#D1D5DB"
                                BorderThickness="1,1,1,0"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter x:Name="ContentSite" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center" 
                                              ContentSource="Header" 
                                              Margin="5,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#DC2626"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#DC2626"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Border" Property="Margin" Value="0,-2,4,0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#4B5563"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#D1D5DB"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#F3F4F6" BorderThickness="0,0,0,2" Panel.ZIndex="10" Padding="10,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.03"/>
            </Border.Effect>

            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock x:Name="WelcomeMessage" Text="Bienvenido(a)" 
                               Foreground="#111827" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                    <Border Width="36" Height="36" CornerRadius="18" Background="#DC2626" Margin="15,0,0,0">
                        <TextBlock Text="👤" Foreground="White" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <Menu DockPanel.Dock="Left" Background="Transparent" VerticalAlignment="Center">
                    <MenuItem Header="Catálogos y Tablas" Style="{StaticResource ModernMenuItemStyle}">
                        <MenuItem.Icon>
                            <Image Source="/Icon/catalogos.png" Width="18" Height="18"/>
                        </MenuItem.Icon>
                        <MenuItem Header="Productos" Click="MenuItemProductos_Click"/>
                        <MenuItem Header="Unidades de Medida" Click="MenuItemUnidades_Click"/>
                        <MenuItem Header="Colecciones" Click="MenuItemColecciones_Click"/>
                        <MenuItem Header="Títulos" Click="MenuItemTitulos_Click"/>
                    </MenuItem>

                    <MenuItem Header="Movimientos" Style="{StaticResource ModernMenuItemStyle}">
                        <MenuItem.Icon>
                            <Image Source="/Icon/movimientos.png" Width="18" Height="18"/>
                        </MenuItem.Icon>
                        <MenuItem Header="Registro de Códigos" Click="MenuItemRegistroCodigos_Click"/>
                        <MenuItem Header="Ingreso de Productos" Click="MenuItemIngresoProductos_Click"/>
                        <MenuItem Header="Salida de Productos"/>
                    </MenuItem>

                    <MenuItem Header="Consultas y Reportes" Style="{StaticResource ModernMenuItemStyle}">
                        <MenuItem.Icon>
                            <Image Source="/Icon/reportes.png" Width="18" Height="18"/>
                        </MenuItem.Icon>
                        <MenuItem Header="Saldos de Productos"/>
                        <MenuItem Header="Kardex de Productos">
                            <MenuItem Header="Kardex Físico"/>
                        </MenuItem>
                        <MenuItem Header="Movimiento de Productos"/>
                        <MenuItem Header="Historial x Código"/>
                    </MenuItem>

                    <MenuItem Header="Salir" Click="BtnSalir_Click" Style="{StaticResource ModernMenuItemStyle}">
                        <MenuItem.Icon>
                            <Image Source="/Icon/salir.png" Width="18" Height="18"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="20,10,20,20" Background="White" BorderThickness="0">
            <TabItem Header="🏠 Inicio">
                <Border Background="White" CornerRadius="15" Padding="40" BorderBrush="#E5E7EB" BorderThickness="1" MaxWidth="800" VerticalAlignment="Top" Margin="0,30,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="5" Direction="270" Color="Black" Opacity="0.05"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Panel de Control de Almacén" FontSize="28" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,10"/>
                        <TextBlock Text="Seleccione una opción en el menú superior para abrir una nueva pestaña de trabajo." 
                                   FontSize="16" Foreground="#6B7280" TextWrapping="Wrap"/>
                        <Border Height="4" Width="60" Background="#DC2626" HorizontalAlignment="Left" Margin="0,20,0,0" CornerRadius="2"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#1F2937" Padding="20,10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="📍" Foreground="#9CA3AF" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Ubicación: ALMACÉN CENTRAL" FontSize="14" Foreground="#E5E7EB" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock Text="🕒" Foreground="#9CA3AF" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock x:Name="DateTimeTextBlock" FontSize="14" Foreground="#E5E7EB" FontWeight="SemiBold"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>