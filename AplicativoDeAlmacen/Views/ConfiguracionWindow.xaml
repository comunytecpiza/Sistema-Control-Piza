<Window x:Class="AplicativoDeAlmacen.ConfiguracionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración Técnica - Solo TI" Height="600" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" FontFamily="Segoe UI" Background="#F3F4F6">

    <Border Background="White" CornerRadius="12" Margin="20" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.1"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="🛠️ Configuración de Red" FontSize="22" FontWeight="Bold" Foreground="#DC2626" Margin="0,0,0,10" TextAlignment="Center"/>
            <TextBlock Text="Ruta de guardado automático: %AppData%\EdicionesPiza" Foreground="#6B7280" FontSize="11" TextAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Motor de Base de Datos (Para el futuro)" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbMotor" Height="35" Margin="0,0,0,15" Padding="5" FontSize="14">
                <ComboBoxItem Content="SQL Server (Actual)" IsSelected="True"/>
                <ComboBoxItem Content="MySQL / MariaDB"/>
                <ComboBoxItem Content="PostgreSQL"/>
                <ComboBoxItem Content="Oracle DB"/>
                <ComboBoxItem Content="MongoDB (NoSQL)"/>
            </ComboBox>

            <TextBlock Text="Servidor (IP o Localhost)" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtServer" Height="35" Margin="0,0,0,15" Padding="5" FontSize="14"/>

            <TextBlock Text="Nombre de la Base de Datos" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtDatabase" Text="EdicionesPizaControl" Height="35" Margin="0,0,0,15" Padding="5" FontSize="14"/>

            <TextBlock Text="Usuario DB" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtUser" Text="sa" Height="35" Margin="0,0,0,15" Padding="5" FontSize="14"/>

            <TextBlock Text="Contraseña DB" Foreground="#4B5563" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="TxtPassword" Height="35" Margin="0,0,0,25" Padding="5" FontSize="14"/>

            <Button Content="GUARDAR CREDENCIALES" Click="BtnGuardar_Click" Background="#DC2626" Foreground="White" FontWeight="Bold" Height="45" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>