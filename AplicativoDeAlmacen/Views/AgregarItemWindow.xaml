<Window x:Class="AplicativoDeAlmacen.Views.AgregarItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AplicativoDeAlmacen.Views"
        mc:Ignorable="d"
        Title="Agregar Ítem al Inventario" 
        Height="520" Width="680"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="#F1F5F9">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2563EB" CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📦" FontSize="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Detalle del Producto a Ingresar" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Producto:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" FontSize="13"/>

                    <Grid Grid.Column="1">
                        <TextBox x:Name="txtProducto" Height="32" VerticalContentAlignment="Center" Padding="5,0" FontSize="13"/>

                        <Popup x:Name="popupProductos" PlacementTarget="{Binding ElementName=txtProducto}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Slide">
                            <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Width="{Binding ElementName=txtProducto, Path=ActualWidth}" MaxHeight="180">
                                <ListBox x:Name="lstSugerenciasProductos" DisplayMemberPath="Descripcion" BorderThickness="0" Background="Transparent" Padding="2"/>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="U. Medida:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" FontSize="13"/>
                    <TextBox x:Name="txtUMedida" Grid.Column="1" Height="32" IsReadOnly="True" Background="#F8FAFC" Foreground="#64748B" FontWeight="Medium" VerticalContentAlignment="Center" Padding="5,0" FontSize="13"/>
                </Grid>

                <UniformGrid Columns="2">
                    <Grid Margin="0,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cantidad:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" FontSize="13"/>
                        <TextBox x:Name="txtCantidad" Grid.Column="1" Height="32" Text="0.00" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Padding="5,0" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Margin="8,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="C. Unitario:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" FontSize="13"/>
                        <TextBox x:Name="txtCUnitario" Grid.Column="1" Height="32" Text="0.00" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Padding="5,0" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>
                </UniformGrid>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="2" Header="🔑 Detalle de Códigos Únicos" BorderBrush="#E2E8F0" Foreground="#1E293B" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,16">
            <DataGrid x:Name="dgDetalleCodigos" 
                     
                      AutoGenerateColumns="False" 
                      HeadersVisibility="Column" 
                      Background="White" 
                      BorderThickness="1" 
                    
                      BorderBrush="#E2E8F0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#F1F5F9"
                      RowHeight="28">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1E293B"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cantidad" Width="90" Binding="{Binding Cantidad}"/>
                    <DataGridTextColumn Header="Desde (Rango Inicial)" Width="140" Binding="{Binding Desde}"/>
                    <DataGridTextColumn Header="Hasta (Rango Final)" Width="140" Binding="{Binding Hasta}"/>
                    <DataGridTextColumn Header="Colección / Tipo de Guía" Width="200*" Binding="{Binding ColeccionTipo}"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnAgregarFilaCodigo" 
            Content="➕ Agregar" 
            Width="110" Height="36" 
            Background="#2563EB" Foreground="White" 
            FontWeight="Bold" FontSize="13"
            BorderThickness="0" Margin="0,0,10,0" 
            Cursor="Hand" Click="BtnAgregarRangoCodigo_Click"/>
            <Button x:Name="btnModificar" Content="Modificar" Click="BtnModificarRangoCodigo_Click"/>
            <Button x:Name="btnGrabar" 
                    Content="💾 Grabar Ítem" 
                    Width="130" Height="36" 
                    Background="#10B981" Foreground="White" 
                    FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Margin="0,0,10,0" 
                    Cursor="Hand" Click="BtnGrabar_Click"/>

            <Button x:Name="btnSalir" 
                    Content="🚪 Salir" 
                    Width="110" Height="36" 
                    Background="#64748B" Foreground="White" 
                    FontWeight="Bold" FontSize="13"
                    BorderThickness="0" 
                    Cursor="Hand" Click="BtnSalir_Click"/>
        </StackPanel>
    </Grid>
</Window>