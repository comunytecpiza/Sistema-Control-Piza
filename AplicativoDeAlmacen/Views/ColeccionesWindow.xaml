<Window x:Class="AplicativoDeAlmacen.Views.ColeccionesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="COLECCIONES" Height="450" Width="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="+ Agregar Colección" Click="AgregarColeccion_Click" Margin="10" Background="Green" Foreground="White" Padding="5" FontSize="15"/>
        <DataGrid x:Name="ColeccionesDataGrid" Grid.Row="1" AutoGenerateColumns="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="AÑO" Binding="{Binding Ano}"/>
                <DataGridTextColumn Header="ESTADO" Binding="{Binding Estado}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Modal para Nueva Colección -->
        <Grid x:Name="ModalBackground" Grid.RowSpan="2" Visibility="Collapsed" Background="#80000000">
            <Border Background="White" CornerRadius="5" Width="300" Height="250">
                <StackPanel Margin="10">
                    <TextBlock Text="Nueva Colección" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
                    <TextBlock Text="AÑO:" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                    <TextBox x:Name="AnoTextBox" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <TextBlock Text="ESTADO:" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                    <ComboBox x:Name="EstadoComboBox" Margin="0,0,0,10" FontSize="15" Padding="5"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="+ Agregar" Click="Agregar_Click" Width="120" Margin="0,0,10,0" Background="Green" Foreground="White" FontSize="15" Padding="5"/>
                        <Button Content="Cancelar" Click="Cancelar_Click" Width="120" Background="Red" Foreground="White" FontSize="15" Padding="5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>