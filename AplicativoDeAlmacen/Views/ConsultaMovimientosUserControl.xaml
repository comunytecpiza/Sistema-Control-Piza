<UserControl x:Class="AplicativoDeAlmacen.Views.ConsultaMovimientosUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6" FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="RightAlignStyle" TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="0,0,10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PANEL SUPERIOR: FILTROS ORDENADOS -->
        <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.05"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Fila 1: Producto -->
                    <TextBlock Text="Producto:" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,15,15"/>
                    <ComboBox x:Name="CboProductos" Grid.Column="1" Height="38" IsEditable="True" Margin="0,0,0,15" SelectionChanged="CboProductos_SelectionChanged" FontSize="14"/>

                    <!-- Fila 2: Filtros de Búsqueda (Aquí están las cajas de texto) -->
                    <TextBlock Text="Filtros:" Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,15,15"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Center">

                        <!-- Razón Social -->
                        <CheckBox x:Name="ChkRazonSocial" Content="Razón Social:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#374151" FontWeight="SemiBold" Click="ChkFiltros_Click"/>
                        <TextBox x:Name="TxtRazonSocial" Width="220" Height="35" Margin="0,0,25,0" IsEnabled="False" VerticalContentAlignment="Center" Padding="8,0" FontSize="13" />

                        <!-- Ubicación -->
                        <CheckBox x:Name="ChkUbicacion" Content="Ubicación:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#374151" FontWeight="SemiBold" Click="ChkFiltros_Click"/>
                        <TextBox x:Name="TxtUbicacion" Width="220" Height="35" IsEnabled="False" VerticalContentAlignment="Center" Padding="8,0" FontSize="13" />

                    </StackPanel>

                    <!-- Fila 3: Opciones y Periodo -->
                    <TextBlock Text="Periodo:" Grid.Row="2" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#4B5563"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">

                        <TextBlock Text="Desde" VerticalAlignment="Center" Foreground="#6B7280" Margin="0,0,10,0"/>
                        <DatePicker x:Name="DpDesde" Width="140" Height="38" Margin="0,0,25,0"/>

                        <TextBlock Text="Hasta" VerticalAlignment="Center" Foreground="#6B7280" Margin="0,0,10,0"/>
                        <DatePicker x:Name="DpHasta" Width="140" Height="38" Margin="0,0,30,0"/>

                        <!-- Tipos (RadioButtons modernos) -->
                        <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="15,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tipo: " FontWeight="SemiBold" Foreground="#6B7280" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <RadioButton Content="Libros Guía" Margin="0,0,15,0" Foreground="#374151" VerticalAlignment="Center"/>
                                <RadioButton Content="Libros Venta" Margin="0,0,15,0" Foreground="#374151" VerticalAlignment="Center"/>
                                <RadioButton Content="Todos" IsChecked="True" Foreground="#374151" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Botones de Acción -->
                <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Bottom">
                    <Button Content="🚀 Ejecutar Consulta" Height="42" Width="170" Margin="0,0,0,10" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="BtnEjecutar_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="🖨️ Imprimir" Height="42" Width="170" Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PANEL INFERIOR: TABLAS Y TOTALES (Sin cambios de diseño) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6.5*"/>
                <ColumnDefinition Width="3.5*"/>
            </Grid.ColumnDefinitions>

            <!-- TABLA IZQUIERDA: MOVIMIENTOS -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,15,0" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#4F46E5" Padding="15,10">
                        <TextBlock Text="📋 Resumen de Movimientos" Foreground="White" FontWeight="Bold" FontSize="15"/>
                    </Border>

                    <DataGrid x:Name="MovimientosDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" HeadersVisibility="Column" RowHeight="35" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy}" Width="90"/>
                            <DataGridTextColumn Header="# Registro" Binding="{Binding NumeroRegistro}" Width="120"/>
                            <DataGridTextColumn Header="Razón Social / Ubicación" Binding="{Binding RazonSocialUbicacion}" Width="*"/>
                            <DataGridTextColumn Header="# Guía" Binding="{Binding NumeroGuia}" Width="110"/>
                            <DataGridTextColumn Header="Ingreso" Binding="{Binding Ingreso, StringFormat=N2}" Width="90" CellStyle="{StaticResource RightAlignStyle}" FontWeight="SemiBold" Foreground="#059669"/>
                            <DataGridTextColumn Header="Salida" Binding="{Binding Salida, StringFormat=N2}" Width="90" CellStyle="{StaticResource RightAlignStyle}" FontWeight="SemiBold" Foreground="#DC2626"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- TOTALES MODERNOS -->
                    <Border Grid.Row="2" Background="#F8FAFC" Padding="15" BorderBrush="#E2E8F0" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <!-- Fila de sumas -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                                <TextBlock Text="Totales Ingreso/Salida:" Foreground="#64748B" FontWeight="Bold" Margin="0,0,20,0" VerticalAlignment="Center" FontSize="13"/>
                                <TextBlock x:Name="TxtTotalIngreso" Text="0.00" Foreground="#059669" FontWeight="Bold" FontSize="16" Width="90" TextAlignment="Right" Margin="0,0,5,0"/>
                                <TextBlock x:Name="TxtTotalSalida" Text="0.00" Foreground="#DC2626" FontWeight="Bold" FontSize="16" Width="90" TextAlignment="Right"/>
                            </StackPanel>
                            <!-- Fila de total vendidos -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Total Vendidos (Salidas Netas):" Foreground="#0F172A" FontWeight="ExtraBold" Margin="0,0,20,0" VerticalAlignment="Center" FontSize="14"/>
                                <Border Background="#FEF2F2" CornerRadius="4" Padding="10,2">
                                    <TextBlock x:Name="TxtTotalVendidos" Text="0.00" Foreground="#B91C1C" FontWeight="Black" FontSize="18" Width="170" TextAlignment="Right"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- TABLA DERECHA: CÓDIGOS -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.05"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Background="#4338CA" Padding="15,10">
                        <TextBlock Text="🏷️ Detalle de Códigos" Foreground="White" FontWeight="Bold" FontSize="15"/>
                    </Border>

                    <DataGrid x:Name="CodigosDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" HeadersVisibility="Column" RowHeight="35" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="*"/>
                            <DataGridTextColumn Header="Colección / Tipo" Binding="{Binding ColeccionTipo}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#EEF2FF" Padding="15" BorderBrush="#E0E7FF" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="TxtTotalCodigos" Text="0 Códigos Registrados" FontWeight="Bold" Foreground="#4F46E5" HorizontalAlignment="Center" FontSize="14"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>