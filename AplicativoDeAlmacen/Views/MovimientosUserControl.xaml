<UserControl x:Class="AplicativoDeAlmacen.Views.MovimientosUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AplicativoDeAlmacen.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1150"
             Background="#F8FAFC"
             FontFamily="Segoe UI">

    <UserControl.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="1" Color="#0F172A" Opacity="0.05"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttonBorder" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="buttonBorder" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="38"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#334155"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#EEF2FF"/>
                                <Setter Property="Foreground" Value="#4F46E5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border BorderBrush="#6366F1" BorderThickness="4,0,0,0" Padding="12,2,0,2" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Registro de Ingreso de Productos" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                <TextBlock Text="Gestión de inventario, proveedores y asignación de códigos únicos" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button x:Name="btnAgregar" 
                        Style="{StaticResource ModernButton}" 
                        Content="➕ Nuevo" 
                        Background="#10B981" 
                        Margin="0,0,8,0" 
                        MinWidth="105"
                        Click="BtnAgregar_Click"/>  

                    <Button x:Name="btnEditar" Style="{StaticResource ModernButton}" Content="📝 Editar" Background="#F59E0B" Margin="0,0,8,0" MinWidth="105"/>
                    <Button x:Name="btnImprimir" Style="{StaticResource ModernButton}" Content="🖨️ Imprimir" Background="#64748B" Margin="0,0,8,0" MinWidth="105"/>
                    <Button x:Name="btnAnular" Style="{StaticResource ModernButton}" Content="🗑️ Anular" Background="#EF4444" MinWidth="105"/>
                </StackPanel>
                <Border CornerRadius="8" Background="White" Padding="20" Effect="{StaticResource CardShadow}">
                    <Grid x:Name="grdFormulario">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="N° Registro" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" Margin="0,0,0,12" FontSize="13"/>

                        <Grid Grid.Column="1" Margin="0,0,20,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="135*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtNumSerie" 
             Grid.Column="0" 
             Height="32" 
             IsReadOnly="True" 
             FontSize="13" 
             FontWeight="Bold" 
             Background="#F8FAFC" 
             HorizontalContentAlignment="Center" 
             VerticalContentAlignment="Center"/>

                            <TextBox x:Name="txtNumDocumento" 
             Grid.Column="2" 
             Height="32" 
             IsReadOnly="True" 
             FontSize="13" 
             FontWeight="Bold" 
             Background="#F8FAFC" 
             HorizontalContentAlignment="Center" 
             VerticalContentAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Fecha de Recepción" Grid.Column="2" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" Margin="0,0,0,12" FontSize="13"/>
                        <DatePicker x:Name="dtpFechaRecepcion" Grid.Column="3" Height="32" Margin="0,0,0,12" FontSize="13" VerticalContentAlignment="Center"/>

                        <TextBlock Text="Motivo" 
                               Grid.Row="1" 
                               VerticalAlignment="Center" 
                               Foreground="#475569" 
                               FontWeight="Medium" 
                               Margin="0,0,0,12" 
                               FontSize="13"/>

                        <ComboBox x:Name="cboMotivo" 
                              Grid.Row="1" 
                              Grid.Column="1" 
                              Grid.ColumnSpan="3" 
                              Height="32" 
                              Margin="0,0,0,12" 
                              FontSize="13"
                              DisplayMemberPath="Descripcion" 
                              SelectedValuePath="Id"/>

                        <TextBlock Text="Razón Social" Grid.Row="2" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" Margin="0,0,0,12" FontSize="13"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,20,12">
                            <TextBox x:Name="txtRazonSocial" Height="32" FontSize="13"/>

                            <Popup x:Name="popupSugerencias"
                                   PlacementTarget="{Binding ElementName=txtRazonSocial}"
                                   Placement="Bottom"
                                   Width="{Binding ActualWidth, ElementName=txtRazonSocial}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4" Effect="{StaticResource CardShadow}">
                                    <ListBox x:Name="lstSugerencias" MaxHeight="160" Background="Transparent" BorderThickness="0" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RazonSocial}" Padding="10,6" FontSize="13" Foreground="#334155"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid> 

                        <TextBlock Text="Código Cliente" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" Margin="0,0,0,12" FontSize="13"/>
                        <TextBox x:Name="txtCodigoRazonSocial" Grid.Row="2" Grid.Column="3" Height="32" Margin="0,0,0,12" IsReadOnly="True" FontSize="13"/>

                        <TextBlock Text="Dirección" Grid.Row="3" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium" Margin="0,0,0,12" FontSize="13"/>
                        <TextBox x:Name="txtDireccion" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Height="32" Margin="0,0,0,12" IsReadOnly="True" FontSize="13"/>

                        <TextBlock Text="Observación" Grid.Row="4" VerticalAlignment="Top" Margin="0,6,0,0" Foreground="#475569" FontWeight="Medium" FontSize="13"/>
                        <TextBox x:Name="txtObservacion" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Height="48" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="8,5" FontSize="13"/>
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" CornerRadius="8" Background="White" Padding="6" Effect="{StaticResource CardShadow}" Height="235" VerticalAlignment="Bottom">
                <Grid>
                    <Image Source="/Images/ingreso-almacen.jpg" Stretch="UniformToFill"/>
                    <Border Background="#1E293B" Opacity="0.03" CornerRadius="4"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button x:Name="btnAgregarProducto" Style="{StaticResource ModernButton}" Content="➕ Agregar Ítem" Background="#007BFF" Margin="0,0,8,0" MinWidth="120"/>
                    <Button x:Name="btnModificar" Style="{StaticResource ModernButton}" Content="✏️ Modificar" Background="#D97706" Margin="0,0,8,0" MinWidth="110"/>
                    <Button x:Name="btnEliminar" Style="{StaticResource ModernButton}" Content="🗑️ Eliminar" Background="#DC2626" Margin="0,0,8,0" MinWidth="110"/>
                    
                    <Button x:Name="btnImportar" Style="{StaticResource ModernButton}" Content="📥 Importar de Excel" Background="#7C3AED" MinWidth="150"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button x:Name="btnGrabar" Style="{StaticResource ModernButton}" Content="💾 Guardar Entrada" Background="#1E293B" Margin="0,0,8,0" MinWidth="150" Click="RegistrarMovimientoCompleto"/>
                    <Button x:Name="btnCancelar" 
                            Style="{StaticResource ModernButton}" 
                            Content="❌ Cancelar" 
                            Background="#64748B" 
                            Margin="0,0,8,0" 
                            MinWidth="105"
                            Click="BtnCancelar_Click"/>         

                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Cursor="">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#4F46E5" CornerRadius="6,6,0,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Productos Recibidos" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,6,6" Padding="2" Effect="{StaticResource CardShadow}">
                        <DataGrid x:Name="dgProductos" Style="{StaticResource ModernDataGrid}">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                </Style>
                            </DataGrid.Resources>
                           
                        </DataGrid>
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#1E293B" CornerRadius="6,6,0,0" Padding="12,5">
                        <DockPanel LastChildFill="True">
                            <StackPanel Orientation="Horizontal"  VerticalAlignment="Center">
                                <TextBlock Text="🔑" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Detalle de Códigos" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="btnDescargarExcel" Content="📊 Exportar Excel" Foreground="#93C5FD" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right" Padding="4" FontSize="12" FontWeight="SemiBold" Cursor="Hand"/>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,6,6" Padding="2" Effect="{StaticResource CardShadow}">
                        <DataGrid x:Name="dgCodigos" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="N° Fila" Binding="{Binding NumeroFila}" Width="60"/>
                                <DataGridTextColumn Header="Código Único" Binding="{Binding CodigoUnique}" Width="*"/>
                                <DataGridTextColumn Header="Tipo de Colección" Binding="{Binding ColeccionTipo}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>