<Window x:Class="AplicativoDeAlmacen.Views.IngresoProductosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ingreso de Productos" Height="700" Width="1200">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
			<ColumnDefinition Width="Auto"/>
		</Grid.ColumnDefinitions>

		<!-- Panel Izquierdo -->
		<StackPanel Grid.Column="0" Margin="10">
			<!-- Botones superiores -->
			<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
				<Button x:Name="btnAgregar" Content="+ Agregar" Width="100" Height="28"
                        Background="#FF00B050" Foreground="White" Margin="0,0,10,0" FontSize="15" Click="btnAgregar_Click_1"/>
				<Button x:Name="btnEditar" Content="Editar" Width="100" Height="28"
                        Background="#FFED7D31" Foreground="White" Margin="0,0,10,0" FontSize="15"/>
				<Button x:Name="btnImprimir" Content="Imprimir" Width="100" Height="28"
                        Background="#FF7F7F7F" Foreground="White" Margin="0,0,10,0" FontSize="15"/>
				<Button x:Name="btnAnular" Content="Anular" Width="100" Height="28"
                        Background="Red" Foreground="White" FontSize="15"/>
			</StackPanel>

			<!-- Formulario -->
			<Grid x:Name="grdFormulario" Margin="0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<!-- Primera fila -->
				<TextBlock Text="# Registro" VerticalAlignment="Center" FontSize="15" FontWeight="Bold"/>
				<TextBox x:Name="txtRegistro" Grid.Column="1" Height="23" Margin="5,2" IsReadOnly="True" FontSize="15" />

				<TextBlock Text="Fecha de Recepción:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="15" FontWeight="Bold"/>
				<DatePicker x:Name="dtpFechaRecepcion" Grid.Column="3" Height="23" Margin="5,2" FontSize="15"/>

				<!-- Segunda fila -->
				<TextBlock Text="Motivo:" Grid.Row="1" VerticalAlignment="Center" FontSize ="15" FontWeight="Bold"/>
				<ComboBox x:Name="cboMotivo" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
                         Height="23" Margin="5,2" FontSize="15"/>

				<!-- Tercera fila -->
				<TextBlock Text="Razón Social:" Grid.Row="2" VerticalAlignment="Center" FontSize="15" FontWeight="Bold"/>
				<Grid Grid.Row="2" Grid.Column="1" Margin="5,2">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<TextBox x:Name="txtRazonSocial" Height="23" FontSize="15"/>

					<Popup x:Name="popupSugerencias"
						   PlacementTarget="{Binding ElementName=txtRazonSocial}"
						   Placement="Bottom"
						   Width="{Binding ActualWidth, ElementName=txtRazonSocial}"
						   AllowsTransparency="True"
						   PopupAnimation="Slide">
						<ListBox x:Name="lstSugerencias"
								 MaxHeight="150"
								 Background="White"
								 BorderBrush="#FFABADB3"
								 BorderThickness="1"
								 VirtualizingPanel.IsVirtualizing="True"
								 VirtualizingPanel.VirtualizationMode="Recycling"
								 ScrollViewer.VerticalScrollBarVisibility="Auto">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Text="{Binding RazonSocial}" Padding="5,2"/>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</Popup>
				</Grid>

				<TextBlock Text="Código:" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="15" FontWeight="Bold"/>
				<TextBox x:Name="txtCodigoRazonSocial" Grid.Row="2" Grid.Column="3"
                         Height="23" Margin="5,2" IsReadOnly="True" FontSize="15"/>

				<!-- Cuarta fila -->
				<TextBlock Text="Dirección:" Grid.Row="3" VerticalAlignment="Center" FontSize="15" FontWeight="Bold"/>
				<TextBox x:Name="txtDireccion" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                         Height="23" Margin="5,2" IsReadOnly="True" FontSize="15"/>

				<!-- Quinta fila -->
				<TextBlock Text="Observación:" Grid.Row="4" VerticalAlignment="Center" FontSize="15" FontWeight="Bold"/>
				<TextBox x:Name="txtObservacion" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                         Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="5,2" FontSize="15"/>
			</Grid>
		</StackPanel>

		<!-- Imagen del almacén -->
		<Image Grid.Column="1" Source="/Images/ingreso-almacen.jpg"
               Width="400" Height="250" Stretch="UniformToFill" Margin="0,10,10,0"/>

		<!-- Panel Inferior -->
		<Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="10">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Botones inferiores -->
			<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
				<Button x:Name="btnAgregarProducto" Content="+ Agregar" Width="100" Height="28"
                        Background="#FF00B050" Foreground="White" Margin="0,0,10,0" FontSize="15"/>
				<Button x:Name="btnModificar" Content="Modificar" Width="100" Height="28"
                        Background="#FFED7D31" Foreground="White" Margin="0,0,10,0" FontSize="15"/>
				<Button x:Name="btnEliminar" Content="Eliminar" Width="100" Height="28"
                        Background="Red" Foreground="White" Margin="0,0,10,0" FontSize="15"/>
				<Button x:Name="btnImportar" Content="Importar" Width="100" Height="28"
                        Background="DeepPink" Foreground="White" Margin="0,0,10,0" FontSize="15" Click="btnImportar_Click"/>
				<Button x:Name="btnGrabar" Content="Grabar" Width="100" Height="28"
                        Background="Black" Foreground="White" Margin="0,0,10,0" FontSize="15"/>
				<Button x:Name="btnCancelar" Content="Cancelar" Width="100" Height="28"
                        Background="Red" Foreground="White" FontSize="15"/>
			</StackPanel>

			<!-- Tablas -->
			<Grid Grid.Row="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>

				<!-- Tabla Productos Recibidos -->
				<Grid Grid.Column="0" Margin="0,0,5,0">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Border Background="Blue">
						<TextBlock Text="Productos Recibidos" Foreground="White" Padding="5" FontSize="15"/>
					</Border>

					<DataGrid x:Name="dgProductos" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="100"/>
							<DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
							<DataGridTextColumn Header="U. Medida" Binding="{Binding UnidadMedida}" Width="100"/>
							<DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
							<DataGridTextColumn Header="C. Unitario" Binding="{Binding CostoUnitario}" Width="100"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>

				<!-- Tabla Detalle de Códigos -->
				<Grid Grid.Column="1" Margin="5,0,0,0">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<DockPanel Grid.Row="0" Background="Blue" LastChildFill="True">
						<TextBlock Text="Detalle de Códigos" Foreground="White" Padding="5" DockPanel.Dock="Left" FontSize="15"/>
						<Button x:Name="btnDescargarExcel" Content="Descargar Excel de Códigos"
                                Foreground="White" Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Right" Padding="5" FontSize="15"/>
					</DockPanel>

					<DataGrid x:Name="dgCodigos" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
						<DataGrid.Columns>
							<DataGridTextColumn Header="N°Fila" Binding="{Binding NumeroFila}" Width="100"/>
							<DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="*"/>
							<DataGridTextColumn Header="Colección / Tipo" Binding="{Binding ColeccionTipo}" Width="150"/>
						</DataGrid.Columns>
					</DataGrid>
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</Window>