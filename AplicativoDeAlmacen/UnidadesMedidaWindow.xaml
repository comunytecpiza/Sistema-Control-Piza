<Window x:Class="AplicativoDeAlmacen.Views.UnidadesMedidaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unidades de Medida" Height="600" Width="800">
	<Grid>
		<!-- Contenido principal -->
		<Grid x:Name="MainContent">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Text="Unidades de Medida" FontSize="30" FontWeight="Bold" Margin="20,20,20,10"/>

			<StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,20,10">
				<TextBox x:Name="UnidadSearchBox" Width="200" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="15"/>
				<Button Content="Buscar" Width="160" Click="UnidadSearchButton_Click" Background="Blue" Foreground="White" FontSize="15"/>
				<Button Content="+ Agregar Unidad" Width="160" Margin="10,0,0,0" Padding="5"  Click="AddUnidadButton_Click" Background="Green" Foreground="White" FontSize="15"/>
				<Button Content="Editar Unidad" Width="160" Margin="10,0,0,0" Padding="5" Click="EditUnidadButton_Click" Background="#ecab0f" Foreground="White" FontSize="15"/>
			</StackPanel>

			<DataGrid x:Name="UnidadGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Margin="20">
				<DataGrid.Columns>
					<DataGridTextColumn Header="Código" Binding="{Binding Id}" Width="Auto"/>
					<DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
					<DataGridTextColumn Header="Abreviatura" Binding="{Binding Abreviatura}" Width="Auto"/>
					<DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="Auto"/>
				</DataGrid.Columns>
			</DataGrid>

			<Button Grid.Row="3" Content="Cerrar" HorizontalAlignment="Right" Width="150" Margin="0,10,20,20" Click="CloseUnidadWindow_Click" Background="Red" Padding="5" FontSize="15" Foreground="White"/>
		</Grid>

		<!-- Modal para Agregar/Editar Unidad -->
		<Grid x:Name="AddEditUnidadModal" Visibility="Collapsed" Background="#80000000">
			<Border Background="White" Width="300" Height="180" CornerRadius="10">
				<Grid Margin="20">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<TextBlock Text="Descripción:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,5" VerticalAlignment="Center" FontSize="14" FontWeight="bold"/>
					<TextBox x:Name="TxtDescripcionUnidad" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5" Height="25" FontSize="14"/>

					<TextBlock Text="Abreviatura:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,5" VerticalAlignment="Center" FontSize="14" FontWeight="bold"/>
					<TextBox x:Name="TxtAbreviatura" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" Height="25" FontSize="14"/>

					<TextBlock Text="Estado:" Grid.Row="2" Grid.Column="0" Margin="0,0,10,5" VerticalAlignment="Center" FontSize="14" FontWeight="bold"/>
					<ComboBox x:Name="CmbEstadoUnidad" Grid.Row="2" Grid.Column="1" Margin="0,0,0,5" Height="25" FontSize="14">
						<ComboBoxItem Content="ACTIVO" Background="Green"/>
						<ComboBoxItem Content="INACTIVO" Background="Red"/>
					</ComboBox>

					<StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
						<Button Content="Guardar" Width="80" Click="GuardarUnidad_Click" Margin="0,0,10,0" Height="30" Background="Green" Foreground="White" FontSize="15"/>
						<Button Content="Cancelar" Width="80" Click="CancelarAddEditUnidad_Click" Height="30" Background="Red" Foreground="White" FontSize="15"/>
					</StackPanel>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>
