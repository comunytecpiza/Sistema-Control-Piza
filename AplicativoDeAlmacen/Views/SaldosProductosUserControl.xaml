<UserControl x:Class="AplicativoDeAlmacen.Views.SaldosProductosUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6" FontFamily="Segoe UI">

    <UserControl.Resources>
        <Style x:Key="RightAlignStyle" TargetType="DataGridCell">
            <Setter Property="TextBlock.TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="0,0,10,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Saldos y Movimientos de Productos" FontSize="28" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15" BorderBrush="#E5E7EB" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Desde" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="DpDesde" Width="140" Height="38"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Hasta" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker x:Name="DpHasta" Width="140" Height="38"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Filtro rápido" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#6B7280"/>
                        <TextBox x:Name="TxtFiltro" Width="250" Height="38" Padding="10,0" FontSize="14" VerticalContentAlignment="Center" TextChanged="TxtFiltro_TextChanged"/>
                    </StackPanel>
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Ejecutar" Width="120" Margin="0,0,10,0" Background="#2563EB" Foreground="White" Click="BtnEjecutar_Click"/>
                    <Button Content="Imprimir" Width="100" Background="#10B981" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
            <DataGrid x:Name="SaldosDataGrid" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" RowHeight="38" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E5E7EB" Background="White">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FEF3C7"/>
                        <Setter Property="Foreground" Value="#92400E"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="BorderBrush" Value="#E5E7EB"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="100" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                    <DataGridTextColumn Header="S. Inicial" Binding="{Binding StockInicial, StringFormat=N2}" Width="120" CellStyle="{StaticResource RightAlignStyle}"/>
                    <DataGridTextColumn Header="T. Ingresos" Binding="{Binding TotalIngresos, StringFormat=N2}" Width="120" CellStyle="{StaticResource RightAlignStyle}"/>
                    <DataGridTextColumn Header="T. Salidas" Binding="{Binding TotalSalidas, StringFormat=N2}" Width="120" CellStyle="{StaticResource RightAlignStyle}"/>
                    <DataGridTextColumn Header="S. Final" Binding="{Binding StockFinal, StringFormat=N2}" Width="120" FontWeight="Bold" CellStyle="{StaticResource RightAlignStyle}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>