<UserControl x:Class="AplicativoDeAlmacen.Views.UbicacionesUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F9" FontFamily="Segoe UI">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📍 Ubicaciones" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="BuscarTextBox" Width="300" Tag="Buscar por descripción..." TextChanged="BuscarTextBox_TextChanged"/>
                <Button Content="+ Agregar" Click="AgregarUbicacionButton_Click" Background="#10B981" Margin="10,0,10,0"/>
                <Button Content="✏️ Editar" Click="EditarUbicacionButton_Click" Background="#F59E0B"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" CornerRadius="8" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Padding="1">
            <DataGrid x:Name="UbicacionesDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding TipoUbicacion.Nombre}" Width="Auto"/>
                    <DataGridTextColumn Header="Localidad" Binding="{Binding Localidad.Nombre}" Width="Auto"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado.Nombre}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid x:Name="UbicacionModal" Visibility="Collapsed" Background="#A0000000" Grid.RowSpan="2">
            <Border Background="White" Width="450" VerticalAlignment="Center" CornerRadius="8" Padding="25">
                <StackPanel>
                    <TextBlock x:Name="ModalTitle" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Descripción" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtDescripcion" Margin="0,0,0,10"/>
                    <TextBlock Text="Tipo de Ubicación" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbTipoUbicacion" Margin="0,0,0,10"/>
                    <TextBlock Text="Localidad" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbLocalidad" Margin="0,0,0,10"/>
                    <TextBlock Text="Dirección" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtDireccion" Margin="0,0,0,10"/>
                    <TextBlock Text="Departamento" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbDepartamento" SelectionChanged="CmbDepartamento_SelectionChanged" Margin="0,0,0,10"/>
                    <TextBlock Text="Provincia" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbProvincia" SelectionChanged="CmbProvincia_SelectionChanged" Margin="0,0,0,10"/>
                    <TextBlock Text="Distrito" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbDistrito" Margin="0,0,0,10"/>
                    <TextBlock Text="Estado" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbEstado" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Click="BtnCancelarUbicacion_Click" Background="#6B7280" Margin="0,0,10,0"/>
                        <Button Content="Guardar" Click="BtnGuardarUbicacion_Click" Background="#3B82F6"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>