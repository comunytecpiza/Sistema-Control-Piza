<Window x:Class="AplicativoDeAlmacen.Views.LocalidadesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Localidades" Height="600" Width="800">
    <Grid>
        <!-- Contenido principal -->
        <Grid x:Name="MainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Localidades" FontSize="30" FontWeight="Bold" Margin="20,20,20,10"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,0,20,10">
                <TextBox x:Name="LocalidadesSearchBox" Width="200" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="15"/>
                <Button Content="Buscar" Width="160" Click="LocalidadesSearchButton_Click" Background="Blue" Foreground="White" FontSize="15"/>
                <Button Content="+ Agregar Localidad" Width="160" Margin="10,0,0,0" Padding="5"  Click="AddLocalidadButton_Click" Background="Green" Foreground="White" FontSize="15"/>
                <Button Content="Editar Localidad" Width="160" Margin="10,0,0,0" Padding="5" Click="EditLocalidadButton_Click" Background="#ecab0f" Foreground="White" FontSize="15"/>
            </StackPanel>

            <DataGrid x:Name="LocalidadesGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Margin="20">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding Id}" Width="Auto"/>
                    <DataGridTextColumn Header="Descripción" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Estado" Binding="{Binding Estado}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="3" Content="Cerrar" HorizontalAlignment="Right" Width="150" Margin="0,10,20,20" Click="CloseLocalidadesWindow_Click" Background="Red" Padding="5" FontSize="15" Foreground="White"/>
        </Grid>

        <!-- Modal para Agregar/Editar Localidad -->
        <Grid x:Name="AddEditLocalidadModal" Visibility="Collapsed" Background="#80000000">
            <Border Background="White" Width="300" Height="200" CornerRadius="10">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Nombre:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,5"/>
                    <TextBox x:Name="TxtNombreLocalidad" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>

                    <TextBlock Text="Estado:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,5"/>
                    <ComboBox x:Name="CmbEstadoLocalidad" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5">
                        <ComboBoxItem Content="ACTIVO" Background="Green"/>
                        <ComboBoxItem Content="INACTIVO" Background="Red"/>
                    </ComboBox>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Guardar" Width="80" Click="GuardarLocalidad_Click" Margin="0,0,10,0"/>
                        <Button Content="Cancelar" Width="80" Click="CancelarAddEditLocalidad_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>