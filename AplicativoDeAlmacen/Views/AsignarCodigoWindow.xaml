<Window x:Class="AplicativoDeAlmacen.Views.AsignarCodigoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asignar Códigos Únicos" 
        Height="310" Width="460"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="rbLibroGuia" Content="📘 Libros Guía" IsChecked="True" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,30,0" Cursor="Hand"/>
                <RadioButton x:Name="rbLibroVenta" Content="📗 Libros Venta" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <StackPanel VerticalAlignment="Center">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Cantidad:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium"/>
                    <TextBox x:Name="txtSubCantidad" Grid.Column="1" Height="32" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Padding="5,0" FontWeight="Bold"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Desde:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium"/>
                    <Border Grid.Column="1" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1,1,0,1" CornerRadius="4,0,0,4" Padding="8,0" Height="32">
                        <TextBlock x:Name="lblPrefijoDesde" Text="G-" VerticalAlignment="Center" FontWeight="Bold" Foreground="#64748B"/>
                    </Border>
                    <TextBox x:Name="txtDesde" Grid.Column="2" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Hasta:" VerticalAlignment="Center" Foreground="#475569" FontWeight="Medium"/>
                    <Border Grid.Column="1" Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1,1,0,1" CornerRadius="4,0,0,4" Padding="8,0" Height="32">
                        <TextBlock x:Name="lblPrefijoHasta" Text="G-" VerticalAlignment="Center" FontWeight="Bold" Foreground="#64748B"/>
                    </Border>
                    <TextBox x:Name="txtHasta" Grid.Column="2" Height="32" VerticalContentAlignment="Center" Padding="5,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnAceptarRango" Content="💾 Grabar Código" Grid.Column="0" Height="36" Background="#10B981" Foreground="White" FontWeight="Bold" Margin="0,0,6,0" Click="BtnGrabarCodigo_Click" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="btnCancelarRango" Content="🚪 Cancelar" Grid.Column="1" Height="36" Background="#64748B" Foreground="White" FontWeight="Bold" Margin="6,0,0,0" Click="BtnCancelarRango_Click" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
