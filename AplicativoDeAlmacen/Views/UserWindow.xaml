<Window x:Class="AplicativoDeAlmacen.Views.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ventana para agregar usuario" Height="530" Width="450">
	<Grid Background="#80000000">
		<Border Background="White" Width="430" Height="480" CornerRadius="10">
			<StackPanel Margin="20">
				<Image Source="../Images/usuario.png" Width="64" Height="64"/>
				<TextBlock Text="Usuario:" Margin="0,10,0,5" FontSize="15" FontWeight="Bold"/>
				<TextBox x:Name="TxtUsername" Padding="5" FontSize="15"></TextBox>
				<TextBlock Text="Nombres:" Margin="0,10,0,5" FontSize="15" FontWeight="Bold"/>
				<TextBox x:Name="TxtNombres" Padding="5" FontSize="15"></TextBox>
				<TextBlock Text="Contraseña:" Margin="0,10,0,5" FontSize="15" FontWeight="Bold"/>
				<PasswordBox x:Name="TxtPassword" Padding="5" FontSize="15"/>
				<TextBlock Text="Tipo de Usuario:" Margin="0,10,0,5" FontSize="15" FontWeight="Bold"/>
				<ComboBox x:Name="CmbTipoUsuario" Padding="5" FontSize="15">
					<ComboBoxItem Content="Administrador"/>
					<ComboBoxItem Content="Asistente"/>
				</ComboBox>
				<Button Content="Registrar Usuario" Click="BtnRegistrarUsuario_Click"
                        Background="Green" Foreground="White" Margin="0,20,0,0" Padding="5" FontSize="15" FontWeight="Bold"/>
				<Button Content="Cancelar" Click="BtnCancelarRegistro_Click"
                        Background="Red" Foreground="White" Margin="0,10,0,0" Padding="5" FontSize="15" FontWeight="Bold"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>