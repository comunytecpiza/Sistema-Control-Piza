<Window x:Class="AplicativoDeAlmacen.Views.LocalidadesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Localidades"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TÍTULO -->
            <Border Grid.Row="0"
                    Background="White"
                    Margin="20,20,20,10"
                    CornerRadius="8">

                <TextBlock Text="LOCALIDADES"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="20,15"/>
            </Border>

            <!-- BARRA DE ACCIONES -->
            <Border Grid.Row="1"
                    Background="White"
                    Margin="20,0,20,10"
                    CornerRadius="8">

                <StackPanel Orientation="Horizontal"
                            Margin="15">

                    <TextBox x:Name="LocalidadesSearchBox"
                             Width="250"
                             Height="35"
                             VerticalContentAlignment="Center"
                             FontSize="14"/>

                    <Button Content="Buscar"
                            Width="120"
                            Height="35"
                            Margin="10,0,0,0"
                            Click="LocalidadesSearchButton_Click"
                            Background="#007ACC"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="+ Agregar"
                            Width="140"
                            Height="35"
                            Margin="10,0,0,0"
                            Click="AddLocalidadButton_Click"
                            Background="#28A745"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="Editar"
                            Width="140"
                            Height="35"
                            Margin="10,0,0,0"
                            Click="EditLocalidadButton_Click"
                            Background="#FFC107"
                            Foreground="Black"
                            BorderThickness="0"/>
                </StackPanel>

            </Border>

            <!-- TABLA -->
            <Border Grid.Row="2"
                    Background="White"
                    Margin="20,0,20,10"
                    CornerRadius="8">

                <DataGrid x:Name="LocalidadesGrid"
                          Margin="10"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="35"
                          ColumnHeaderHeight="40"
                          FontSize="14"
                          BorderThickness="0">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"
                                    Value="#2C3E50"/>
                            <Setter Property="Foreground"
                                    Value="White"/>
                            <Setter Property="FontWeight"
                                    Value="Bold"/>
                            <Setter Property="Height"
                                    Value="40"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Código"
                                            Binding="{Binding Id}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Nombre"
                                            Binding="{Binding Nombre}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Estado"
                                            Binding="{Binding Estado.Nombre}"
                                            Width="200"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Border>

            <!-- BOTÓN CERRAR -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,20">

                <Button Content="Cerrar"
                        Width="150"
                        Height="40"
                        Click="CloseLocalidadesWindow_Click"
                        Background="#DC3545"
                        Foreground="White"
                        BorderThickness="0"/>
            </StackPanel>

        </Grid>

        <!-- MODAL -->
        <Grid x:Name="AddEditLocalidadModal"
              Visibility="Collapsed"
              Background="#80000000">

            <Border Width="500"
                    Height="280"
                    Background="White"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid Margin="25">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TÍTULO -->
                    <TextBlock Grid.Row="0"
                               Text="Localidad"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#2C3E50"
                               Margin="0,0,0,20"/>

                    <!-- NOMBRE -->
                    <StackPanel Grid.Row="1"
                                Margin="0,0,0,15">

                        <TextBlock Text="Nombre"
                                   FontWeight="SemiBold"/>

                        <TextBox x:Name="TxtNombreLocalidad"
                                 Height="35"/>
                    </StackPanel>

                    <!-- ESTADO -->
                    <StackPanel Grid.Row="2">

                        <TextBlock Text="Estado"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="CmbEstadoLocalidad"
                                  Height="35"/>
                    </StackPanel>

                    <!-- BOTONES -->
                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">

                        <Button Content="Guardar"
                                Width="120"
                                Height="35"
                                Margin="0,0,10,0"
                                Click="GuardarLocalidad_Click"
                                Background="#28A745"
                                Foreground="White"
                                BorderThickness="0"/>

                        <Button Content="Cancelar"
                                Width="120"
                                Height="35"
                                Click="CancelarAddEditLocalidad_Click"
                                Background="#6C757D"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Window>